{
	"info": {
		"_postman_id": "vaani-data-service-collection",
		"name": "Vaani - Data Service APIs",
		"description": "Complete API collection for Vaani (The Farmer Buddy) Data Service.\n\nIncludes Weather, Crop Intelligence, Mandi Prices, and Search endpoints.\n\nBase URL: http://127.0.0.1:8081",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8081",
			"type": "string"
		},
		{
			"key": "pincode",
			"value": "560001",
			"type": "string"
		},
		{
			"key": "state",
			"value": "Karnataka",
			"type": "string"
		},
		{
			"key": "crop",
			"value": "wheat",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Returns health status of the service, DB (PostgreSQL), and Redis."
					}
				}
			]
		},
		{
			"name": "Weather",
			"item": [
				{
					"name": "v1 - Daily Forecast",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/weather/{{pincode}}?days_past=7&days_future=16&force_refresh=false",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "weather", "{{pincode}}"],
							"query": [
								{
									"key": "days_past",
									"value": "7",
									"description": "Number of past days to include (max ~92)"
								},
								{
									"key": "days_future",
									"value": "16",
									"description": "Number of future forecast days"
								},
								{
									"key": "force_refresh",
									"value": "false",
									"description": "Force re-fetch from Open-Meteo, bypassing cache"
								}
							]
						},
						"description": "Fetches daily weather forecast for a pincode. Includes temperature, precipitation, wind, and heavy rain detection.\n\nOpen-Meteo past_days supports up to ~92 days."
					}
				},
				{
					"name": "v2 - Weather Features",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v2/weather/{{pincode}}?days_past=7&days_future=16&include_hourly=false&force_refresh=false",
							"host": ["{{baseUrl}}"],
							"path": ["v2", "weather", "{{pincode}}"],
							"query": [
								{
									"key": "days_past",
									"value": "7",
									"description": "Number of past days"
								},
								{
									"key": "days_future",
									"value": "16",
									"description": "Number of future forecast days"
								},
								{
									"key": "include_hourly",
									"value": "false",
									"description": "Include hourly breakdown data"
								},
								{
									"key": "force_refresh",
									"value": "false",
									"description": "Force re-fetch from Open-Meteo"
								}
							]
						},
						"description": "Fetches weather with computed features: heavy rain detection, dry spell detection, heat/cold wave detection, irrigation windows, and spray windows."
					}
				}
			]
		},
		{
			"name": "Crop - Tier 1 (Catalog)",
			"item": [
				{
					"name": "List Crops",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops?q=&limit=50&offset=0",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops"],
							"query": [
								{
									"key": "q",
									"value": "",
									"description": "Optional search query to filter crops by name"
								},
								{
									"key": "limit",
									"value": "50",
									"description": "Max results to return"
								},
								{
									"key": "offset",
									"value": "0",
									"description": "Pagination offset"
								}
							]
						},
						"description": "Lists all crops with optional search filter. Returns crop name, key, calendar availability, and variety count."
					}
				},
				{
					"name": "List States",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/states",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "states"]
						},
						"description": "Returns all 36 Indian states with their aliases."
					}
				},
				{
					"name": "Crops for State",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops/state/{{state}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops", "state", "{{state}}"]
						},
						"description": "Lists all crops available in a specific state with variety counts and top yield variety."
					}
				},
				{
					"name": "Crops for Season",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops/season/kharif?state={{state}}&limit_crops=25&limit_varieties=5",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops", "season", "kharif"],
							"query": [
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								},
								{
									"key": "limit_crops",
									"value": "25",
									"description": "Max crops to return"
								},
								{
									"key": "limit_varieties",
									"value": "5",
									"description": "Max varieties per crop"
								}
							]
						},
						"description": "Lists crops suitable for a given season (kharif/rabi/zaid) in a state."
					}
				},
				{
					"name": "Crops for Month",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops/month/3?state={{state}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops", "month", "3"],
							"query": [
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								}
							]
						},
						"description": "Lists crops whose sowing window is open for a specific month (1-12) in a state."
					}
				}
			]
		},
		{
			"name": "Crop - Tier 2 (Varieties)",
			"item": [
				{
					"name": "Varieties by Crop & State",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/varieties/{{crop}}?state={{state}}&limit=50&include_raw_text=false",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "varieties", "{{crop}}"],
							"query": [
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								},
								{
									"key": "limit",
									"value": "50",
									"description": "Max varieties to return"
								},
								{
									"key": "include_raw_text",
									"value": "false",
									"description": "Include raw source text for each variety"
								}
							]
						},
						"description": "Lists all varieties of a specific crop available in a state, ordered by yield."
					}
				},
				{
					"name": "Top Varieties Overall",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/varieties/top?state={{state}}&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "varieties", "top"],
							"query": [
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Max varieties to return"
								}
							]
						},
						"description": "Returns the top-yielding varieties across all crops in a state."
					}
				},
				{
					"name": "Resistant Varieties",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/varieties/resistant?crop={{crop}}&state={{state}}&disease=blast&limit=50",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "varieties", "resistant"],
							"query": [
								{
									"key": "crop",
									"value": "{{crop}}",
									"description": "Crop name (required)"
								},
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								},
								{
									"key": "disease",
									"value": "blast",
									"description": "Disease/pest keyword to search for (required)"
								},
								{
									"key": "limit",
									"value": "50",
									"description": "Max results"
								}
							]
						},
						"description": "Finds crop varieties resistant to a specific disease/pest in a state. Uses keyword matching on resistance lines and raw text."
					}
				}
			]
		},
		{
			"name": "Crop - Tier 3 (Calendar)",
			"item": [
				{
					"name": "Crop Calendar Windows",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crop/{{crop}}/calendar",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crop", "{{crop}}", "calendar"]
						},
						"description": "Returns sowing, growth, and harvest month windows for a crop across regions and seasons."
					}
				},
				{
					"name": "Crop Stage (Current/Specific Month)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crop/{{crop}}/stage?month=3",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crop", "{{crop}}", "stage"],
							"query": [
								{
									"key": "month",
									"value": "3",
									"description": "Month number (1-12). If omitted, uses current IST month."
								}
							]
						},
						"description": "Determines the current growth stage (sowing/growth/harvest) of a crop for a given month."
					}
				}
			]
		},
		{
			"name": "Crop - Tier 4 (Weather-Integrated)",
			"item": [
				{
					"name": "v2 - Crop Suitability by Pincode",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v2/crop/suitability/{{pincode}}?month=3&days_future=16&limit_crops=25&limit_varieties=5&force_refresh=false",
							"host": ["{{baseUrl}}"],
							"path": ["v2", "crop", "suitability", "{{pincode}}"],
							"query": [
								{
									"key": "month",
									"value": "3",
									"description": "Month number (optional, defaults to current IST month)"
								},
								{
									"key": "days_future",
									"value": "16",
									"description": "Future forecast days for weather context"
								},
								{
									"key": "limit_crops",
									"value": "25",
									"description": "Max crops to return"
								},
								{
									"key": "limit_varieties",
									"value": "5",
									"description": "Max varieties per crop"
								},
								{
									"key": "force_refresh",
									"value": "false",
									"description": "Force weather re-fetch"
								}
							]
						},
						"description": "Combines weather forecast + crop calendar to recommend suitable crops for a pincode. Weather-aware crop intelligence."
					}
				},
				{
					"name": "v2 - Crop Risk by Pincode",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v2/crop/risk/{{pincode}}?crop={{crop}}&month=3&days_future=16",
							"host": ["{{baseUrl}}"],
							"path": ["v2", "crop", "risk", "{{pincode}}"],
							"query": [
								{
									"key": "crop",
									"value": "{{crop}}",
									"description": "Crop name (required)"
								},
								{
									"key": "month",
									"value": "3",
									"description": "Month number (optional)"
								},
								{
									"key": "days_future",
									"value": "16",
									"description": "Future forecast days"
								}
							]
						},
						"description": "Assesses weather-based risk for a specific crop at a pincode. Considers heavy rain, temperature extremes, etc."
					}
				},
				{
					"name": "v2 - Sowing Window by Pincode",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v2/crop/sowing-window/{{pincode}}?month=3&days_future=16&limit_crops=25",
							"host": ["{{baseUrl}}"],
							"path": ["v2", "crop", "sowing-window", "{{pincode}}"],
							"query": [
								{
									"key": "month",
									"value": "3",
									"description": "Month number (optional)"
								},
								{
									"key": "days_future",
									"value": "16",
									"description": "Future forecast days"
								},
								{
									"key": "limit_crops",
									"value": "25",
									"description": "Max crops to return"
								}
							]
						},
						"description": "Identifies optimal sowing windows for crops at a pincode based on weather forecast and crop calendar data."
					}
				}
			]
		},
		{
			"name": "Crop - Tier 5 (Decision Support)",
			"item": [
				{
					"name": "Compare Crops",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops/compare?crops=wheat,rice&state={{state}}&month=3",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops", "compare"],
							"query": [
								{
									"key": "crops",
									"value": "wheat,rice",
									"description": "Comma-separated crop names to compare (required)"
								},
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								},
								{
									"key": "month",
									"value": "3",
									"description": "Month number (optional, defaults to current IST month)"
								}
							]
						},
						"description": "Side-by-side comparison of multiple crops in a state: variety count, max yield, sowing window status."
					}
				},
				{
					"name": "Crop Type Stats",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/crops/{{crop}}/types?state={{state}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "crops", "{{crop}}", "types"],
							"query": [
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State name (required)"
								}
							]
						},
						"description": "Returns variety type breakdown (hybrid, improved, local etc.) with yield stats for a crop in a state."
					}
				}
			]
		},
		{
			"name": "Mandi (Market Prices)",
			"item": [
				{
					"name": "v1 - Raw Mandi Prices",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/mandi/raw?state=Rajasthan&district=&market=&commodity=Wheat&limit=50&offset=0",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "mandi", "raw"],
							"query": [
								{
									"key": "state",
									"value": "Rajasthan",
									"description": "State name (required, min 2 chars)"
								},
								{
									"key": "district",
									"value": "",
									"description": "District name (optional)"
								},
								{
									"key": "market",
									"value": "",
									"description": "Market/mandi name (optional)"
								},
								{
									"key": "commodity",
									"value": "Wheat",
									"description": "Commodity/crop name (optional)"
								},
								{
									"key": "limit",
									"value": "50",
									"description": "Max results (1-500)"
								},
								{
									"key": "offset",
									"value": "0",
									"description": "Pagination offset"
								}
							]
						},
						"description": "Fetches raw mandi price data from Data.gov.in Agmarknet API. Returns modal, min, max prices per quintal."
					}
				},
				{
					"name": "v2 - Mandi Insights",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v2/mandi/insights?state=Rajasthan&district=&market=&commodity=Wheat&days=30&group_by=market&force_refresh=false",
							"host": ["{{baseUrl}}"],
							"path": ["v2", "mandi", "insights"],
							"query": [
								{
									"key": "state",
									"value": "Rajasthan",
									"description": "State name (required, min 2 chars)"
								},
								{
									"key": "district",
									"value": "",
									"description": "District name (optional)"
								},
								{
									"key": "market",
									"value": "",
									"description": "Market/mandi name (optional)"
								},
								{
									"key": "commodity",
									"value": "Wheat",
									"description": "Commodity/crop name (optional)"
								},
								{
									"key": "days",
									"value": "30",
									"description": "Lookback period: 7, 30, 90, or 365"
								},
								{
									"key": "group_by",
									"value": "market",
									"description": "Group results by: market, district, or commodity"
								},
								{
									"key": "force_refresh",
									"value": "false",
									"description": "Force re-fetch from Data.gov.in"
								}
							]
						},
						"description": "Aggregated mandi price insights with trends, grouped by market/district/commodity."
					}
				}
			]
		},
		{
			"name": "Search",
			"item": [
				{
					"name": "Global Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/search?q=wheat&state={{state}}&limit=25",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "search"],
							"query": [
								{
									"key": "q",
									"value": "wheat",
									"description": "Search query (required)"
								},
								{
									"key": "state",
									"value": "{{state}}",
									"description": "State context for search (optional)"
								},
								{
									"key": "limit",
									"value": "25",
									"description": "Max results"
								}
							]
						},
						"description": "Global search across crops, varieties, and mandi data."
					}
				}
			]
		}
	]
}