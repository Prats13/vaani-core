[Unit]
Description=Vaani Core - FastAPI Application Server
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/vaani-core
EnvironmentFile=/home/ubuntu/vaani-core/.env
ExecStart=/home/ubuntu/vaani-core/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8010 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vaani-core

[Install]
WantedBy=multi-user.target